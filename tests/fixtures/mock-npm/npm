#!/usr/bin/env bash
# npm الوهمي — لاختبارات التركيب المعزولة لـ typescript-lsp فقط. لا يلمس الشبكة إطلاقًا.
# يقرأ ./package.json في مجلد العمل الحالي ويصنع شجرة node_modules مطابقة
# للنسخ المثبّتة في dependencies (typescript-language-server وtypescript).
set -euo pipefail

if [ -n "${MOCK_NPM_CALLS_FILE:-}" ]; then
  echo "$*" >> "$MOCK_NPM_CALLS_FILE"
fi

[ "${1:-}" = "install" ] || exit 0

pkg="$(pwd)/package.json"
[ -f "$pkg" ] || { echo "mock-npm: لا يوجد package.json في $(pwd)" >&2; exit 1; }

ls_version="$(node -p "require('$pkg').dependencies['typescript-language-server']")"
ts_version="$(node -p "require('$pkg').dependencies['typescript']")"

mkdir -p node_modules/.bin
mkdir -p node_modules/typescript-language-server/lib
mkdir -p node_modules/typescript/lib

printf '{"name":"typescript-language-server","version":"%s"}\n' "$ls_version" \
  > node_modules/typescript-language-server/package.json
printf '{"name":"typescript","version":"%s"}\n' "$ts_version" \
  > node_modules/typescript/package.json

cat > node_modules/typescript/lib/tsserver.js <<'JS'
// mock tsserver.js fixture -- test double, not real TypeScript.
JS

cat > node_modules/typescript-language-server/lib/cli.js <<'JS'
#!/usr/bin/env node
const args = process.argv.slice(2);
const pkg = require('../package.json');
if (args.includes('--version')) {
  console.log(pkg.version);
  process.exit(0);
}
setTimeout(() => process.exit(0), 200);
JS
chmod +x node_modules/typescript-language-server/lib/cli.js

ln -sf ../typescript-language-server/lib/cli.js node_modules/.bin/typescript-language-server
